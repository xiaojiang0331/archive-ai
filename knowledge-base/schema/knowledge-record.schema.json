{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archive-ai.local/schemas/knowledge-record.schema.json",
  "title": "Archive AI Knowledge Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "title",
    "jurisdiction",
    "topics",
    "summary",
    "sourceIds",
    "checkedAt",
    "reviewDue",
    "riskLevel",
    "humanReviewRequired",
    "status"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "minLength": 3 },
    "jurisdiction": { "const": "AU" },
    "topics": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "applicableRoles": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "applicability": { "type": "string" },
    "effectiveFrom": { "type": ["string", "null"], "format": "date" },
    "effectiveTo": { "type": ["string", "null"], "format": "date" },
    "summary": { "type": "string", "minLength": 20 },
    "procedure": { "type": "array", "items": { "type": "string" } },
    "evidenceRequired": { "type": "array", "items": { "type": "string" } },
    "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "checkedAt": { "type": "string", "format": "date" },
    "reviewDue": { "type": "string", "format": "date" },
    "riskLevel": { "enum": ["low", "medium", "high"] },
    "humanReviewRequired": { "type": "boolean" },
    "reviewer": { "type": ["string", "null"] },
    "status": { "enum": ["draft", "reviewed", "published", "superseded"] },
    "supersedes": { "type": ["string", "null"] }
  }
}
